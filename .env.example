# Comma-separated daemon serverIds allowed to use this relay.
# Unset = open relay (anyone with the URL can use it; still zero-knowledge).
RELAY_ALLOWED_SERVER_IDS=

# Port the relay is reachable on (default 8787). Works under both Docker (the
# published host port) and a direct `npm start` (the bind port).
RELAY_PORT=8787

# Bind address. Only `npm start` uses this; under Docker the image pins it to
# 0.0.0.0 (required for the published port to reach the container).
RELAY_HOST=127.0.0.1
